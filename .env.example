# Copie para .env na raiz do projeto (nao commite .env).
# Expo carrega EXPO_PUBLIC_* no bundle (ver documentacao Expo / EAS Secrets).

# Obrigatorio para auth e dados
EXPO_PUBLIC_SUPABASE_URL=https://SEU_REFERENCIAL.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon

# API FastAPI de ML (producao: https://seu-servico.onrender.com sem barra final)
# Vazio = desenvolvimento: http://127.0.0.1:8001 (Android emulador: 10.0.2.2)
EXPO_PUBLIC_ML_API_URL=

# LGPD: URL publica da politica de privacidade (abre no login se definido)
EXPO_PUBLIC_PRIVACY_POLICY_URL=

# Opcional: Sentry DSN; builds EAS / Dev Client (Sentry omitido no Expo Go)
EXPO_PUBLIC_SENTRY_DSN=

# LibreView: URL publica da Supabase Function ou backend que sincroniza leituras
# Exemplo Supabase:
# EXPO_PUBLIC_LIBRE_VIEW_SYNC_URL=https://SEU-PROJETO.supabase.co/functions/v1/libreview-sync
EXPO_PUBLIC_LIBRE_VIEW_SYNC_URL=

# API ML (servidor FastAPI): origens CORS permitidas, separadas por virgula (vazio = *)
ML_CORS_ORIGINS=
